# Copy to .env and fill in your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model id (see https://ai.google.dev/gemini-api/docs/models). gemini-1.5-* is no longer available.
# Cheaper option: gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
# Used to sign login tokens (change in production)
JWT_SECRET=change-me-to-a-long-random-string
